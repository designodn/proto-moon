{
  "_readme": {
    "что_это": "КОНТРАКТ модели фидов NV-ленты (new-vision/lenta.html). «Расчерчены» все типы карточек по фактической разметке. По этому контракту строится лист «Посты» в гугл-таблице и применятор components/feed-data.js.",
    "источник_разметки": "new-vision/lenta.html (карточки 1–23)",
    "принцип": "Общая ОБЁРТКА (необязательные слоты шапки) + ТЕЛО по component/variant. Слот, которого нет в данных → применятор удаляет узел (а не оставляет пустым).",
    "обёртка_слоты": {
      "id": "строковый ключ поста (p1, p2 …)",
      "component": "тип карточки: feed-base | feed-ad | feed-congrats | feed-questions | feed-group | feed-discussion | feed-memory | feed-contest | feed-stories",
      "variant": "подтип: feed-base → text|photo|gallery|clip|video|article; feed-congrats → birthday|gift",
      "entity": "user | self | group (флаг data-entity; влияет на бейдж «Сообщество» и переход по автору)",
      "breadcrumbs": "массив крошек; последний элемент — активная рубрика (__state-on). Элемент = строка ИЛИ {label, badge} (badge — напр. Дзен). null → крошек нет",
      "title": "h2.nv-feed__title; null → нет заголовка",
      "subtitle": "подзаголовок (в NV-классе пока нет, в данные кладём заране); null → нет",
      "authorId": "ССЫЛКА на data/people.json (person|group). Аватар/имя/«Сообщество» берутся оттуда. null → см. author",
      "author": "инлайн-автор, если НЕ из реестра (реклама, self «Вы»): {name, initials?, avatar?, subtitle?, role}",
      "time": "строка времени поста (11:18, «5 лет назад», «Реклама 0+» — для рекламы кладём в author.subtitle)"
    },
    "тело_общее": {
      "text": "{ value, clamp? } — clamp = число строк до «Раскрыть»",
      "media": "kind: none|image|video|gallery|clip. Поля по kind — см. примеры. url с okcdn детектится на сборке (image/video)",
      "stats": "{ likes, comments, reshares } — actions-bar",
      "buttons": "массив CTA-кнопок { label, style } (secondary|primary|gift)"
    },
    "разрешение_автора": "Если есть authorId — применятор берёт person/group из people.json (фото, имя, для group → подпись «Сообщество»). Иначе рендерит inline author. Так аватарки авторов не дублируются.",
    "слот_матрица": {
      "feed-base/text":     { "breadcrumbs": true, "title": false, "author": true,  "media": "none",    "stats": true },
      "feed-base/photo":    { "breadcrumbs": true, "title": false, "author": true,  "media": "image",   "stats": true },
      "feed-base/gallery":  { "breadcrumbs": false,"title": false, "author": true,  "media": "gallery", "stats": true },
      "feed-base/clip":     { "breadcrumbs": true, "title": false, "author": true,  "media": "clip",    "stats": true },
      "feed-base/video":    { "breadcrumbs": true, "title": false, "author": true,  "media": "video",   "stats": true },
      "feed-base/article":  { "breadcrumbs": true, "title": true,  "author": true,  "media": "image",   "stats": true, "_note": "Дзен: бейдж в крошке, лид-текст без clamp" },
      "feed-ad":            { "breadcrumbs": false,"title": false, "author": "inline","media": "image", "stats": false, "buttons": true },
      "feed-congrats/birthday": { "title": true, "author": false, "friends": true, "buttons": true, "_note": "большой аватар героя сверху" },
      "feed-congrats/gift": { "title": false, "author": true, "giftCard": true, "buttons": true },
      "feed-questions":     { "breadcrumbs": true, "title": true, "questions": true },
      "feed-group":         { "title": true, "friends": true, "buttons": true, "_note": "аватар группы сверху" },
      "feed-discussion":    { "breadcrumbs": true, "title": true, "topComment": true, "moreRepliesLabel": true, "commentInput": true },
      "feed-memory":        { "breadcrumbs": true, "title": true, "author": "self", "media": "image", "buttons": true },
      "feed-contest":       { "breadcrumbs": true, "title": true, "images": true, "buttons": true },
      "feed-stories":       { "_variants": "top (карусель сториз) | moments (крошки+title+аватарки с подписями)" }
    }
  },

